module Umbra.Test where

import Umbra.Types
import Umbra.DarkPool
import Umbra.Lending
import Umbra.Oracle
import DA.Time (time)
import DA.Date (date, Month(..))
import Daml.Script

-- | Test dark pool order creation and matching
testDarkPool : Script ()
testDarkPool = script do
  operator <- allocateParty "Operator"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"

  let startTime = time (date 2026 Jan 15) 12 0 0
  setTime startTime

  -- Create pause contract first
  pauseCid <- submit operator do
    createCmd ProtocolPause with
      operator
      isPaused = False
      reason = ""
      pausedAt = None

  -- Setup: create dark pool operator
  poolOp <- submit operator do
    createCmd DarkPoolOperator with operator, pauseCid

  -- ─── Trader-initiated order via OrderRequest pattern ───

  -- Alice creates an order request (trader-initiated, signed by Alice)
  aliceReq <- submit alice do
    createCmd OrderRequest with
      trader = alice
      operator
      baseAsset = "BTC"
      quoteAsset = "USDC"
      side = Buy
      price = 50000.0
      quantity = 2.0
      minPrice = 49000.0
      maxPrice = 51000.0

  -- Operator accepts Alice's order request → creates co-signed SpotOrder
  buyOrder <- submit operator do
    exerciseCmd aliceReq AcceptOrderRequest

  -- Bob creates an order request
  bobReq <- submit bob do
    createCmd OrderRequest with
      trader = bob
      operator
      baseAsset = "BTC"
      quoteAsset = "USDC"
      side = Sell
      price = 50000.0
      quantity = 1.0
      minPrice = 49000.0
      maxPrice = 51000.0

  -- Operator accepts Bob's order request
  sellOrder <- submit operator do
    exerciseCmd bobReq AcceptOrderRequest

  -- Operator partially fills Alice's buy by 1.0 BTC.
  (_, _, buyResidualOpt, _) <- submit operator do
    exerciseCmd buyOrder FillOrder with
      fillPrice = 50000.0
      fillQuantity = 1.0
      counterparty = bob

  -- Bob's sell is fully filled.
  (_, _, _, _) <- submit operator do
    exerciseCmd sellOrder FillOrder with
      fillPrice = 50000.0
      fillQuantity = 1.0
      counterparty = alice

  buyResidual <- case buyResidualOpt of
    Some cid -> pure cid
    None -> abort "Expected residual buy order after partial fill"

  -- ─── Operator-created order (backwards compatibility) ───

  sellOrder2 <- submit operator do
    exerciseCmd poolOp CreateOrder with
      trader = bob
      baseAsset = "BTC"
      quoteAsset = "USDC"
      side = Sell
      price = 50000.0
      quantity = 1.0

  (_, _, _, _) <- submit operator do
    exerciseCmd buyResidual FillOrder with
      fillPrice = 50000.0
      fillQuantity = 1.0
      counterparty = bob

  (_, _, _, _) <- submit operator do
    exerciseCmd sellOrder2 FillOrder with
      fillPrice = 50000.0
      fillQuantity = 1.0
      counterparty = alice

  -- ─── Price protection test: fill outside bounds must fail ───

  priceTestReq <- submit alice do
    createCmd OrderRequest with
      trader = alice
      operator
      baseAsset = "ETH"
      quoteAsset = "USDC"
      side = Buy
      price = 3000.0
      quantity = 5.0
      minPrice = 2900.0
      maxPrice = 3100.0

  priceTestOrder <- submit operator do
    exerciseCmd priceTestReq AcceptOrderRequest

  -- Fill at price below minPrice should fail
  submitMustFail operator do
    exerciseCmd priceTestOrder FillOrder with
      fillPrice = 2800.0
      fillQuantity = 1.0
      counterparty = bob

  -- Fill at price above maxPrice should fail
  submitMustFail operator do
    exerciseCmd priceTestOrder FillOrder with
      fillPrice = 3200.0
      fillQuantity = 1.0
      counterparty = bob

  -- ─── Trader cancellation test ───

  -- Trader can cancel their own order via TraderCancelOrder
  submitMulti [alice] [operator] do
    exerciseCmd priceTestOrder TraderCancelOrder

  -- ─── Withdraw order request test ───

  withdrawReq <- submit alice do
    createCmd OrderRequest with
      trader = alice
      operator
      baseAsset = "SOL"
      quoteAsset = "USDC"
      side = Buy
      price = 100.0
      quantity = 10.0
      minPrice = 90.0
      maxPrice = 110.0

  -- Alice can withdraw her own request before operator accepts
  submit alice do
    exerciseCmd withdrawReq WithdrawOrderRequest

  return ()

-- | Test lending pool operations with decentralized authorization
testLending : Script ()
testLending = script do
  operator <- allocateParty "Operator"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  oracle <- allocateParty "Oracle"

  let startTime = time (date 2026 Jan 15) 12 0 0
  setTime startTime

  -- Create pause contract
  pauseCid <- submit operator do
    createCmd ProtocolPause with
      operator
      isPaused = False
      reason = ""
      pausedAt = None

  -- Create oracle prices with operator as observer so lending pool can read them
  usdcOracle <- submit oracle do
    createCmd OraclePrice with
      oracle
      observers = [operator, alice, bob]
      asset = "USDC"
      price = 1.0
      lastUpdated = startTime
      minPrice = 0.90
      maxPrice = 1.10
      maxChangePercent = 0.1

  ccOracle <- submit oracle do
    createCmd OraclePrice with
      oracle
      observers = [operator, alice, bob]
      asset = "CC"
      price = 10.0
      lastUpdated = startTime
      minPrice = 0.01
      maxPrice = 100.0
      maxChangePercent = 0.5

  let rateModel = RateModelParams with
        baseRate = 0.02
        multiplier = 0.1
        jumpMultiplier = 3.0
        kink = 0.80

  pool <- submit operator do
    createCmd LendingPool with
      operator
      asset = "USDC"
      totalSupply = 0.0
      totalBorrows = 0.0
      reserves = 0.0
      reserveFactor = 0.10
      borrowCap = Some 1200.0
      rateModel
      collateralConfig = defaultCCCollateral
      lastUpdateTime = startTime
      accumulatedIndex = 1.0
      borrowIndex = 1.0
      pauseCid

  -- ─── USER-INITIATED: Alice supplies 10000 USDC ───
  -- Alice exercises Supply directly (readAs operator to see pool)
  (pool2, supplyPos, _) <- submitMulti [alice] [operator] do
    exerciseCmd pool Supply with
      supplier = alice
      amount = 10000.0

  -- Verify operator alone cannot supply on behalf of user
  submitMustFail operator do
    exerciseCmd pool2 Supply with
      supplier = alice
      amount = 100.0

  -- ─── USER-INITIATED: Bob borrows 1000 USDC with 200 CC collateral ───
  (pool3, borrowPos, _) <- submitMulti [bob] [operator] do
    exerciseCmd pool2 Borrow with
      borrower = bob
      borrowAmount = 1000.0
      collateralAmount = 200.0
      oracleCid = usdcOracle
      collateralOracleCid = ccOracle

  -- Check health factor
  hf <- submit bob do
    exerciseCmd borrowPos GetHealthFactor with
      borrowOracleCid = usdcOracle
      collateralOracleCid = ccOracle
      currentIndex = 1.0

  assertMsg "Health factor should be > 1" (hf > 1.0)

  -- Accrue interest (operator-only admin)
  let nextDay = time (date 2026 Jan 16) 12 0 0
  setTime nextDay

  pool4 <- submit operator do
    exerciseCmd pool3 AccrueInterest

  -- ─── USER-INITIATED: Bob partially repays ───
  (pool5, residualOpt, _) <- submitMulti [bob] [operator] do
    exerciseCmd pool4 RepayBorrow with
      borrower = bob
      positionCid = borrowPos
      repayAmount = 250.0

  residualBorrow <- case residualOpt of
    Some cid -> pure cid
    None -> abort "Expected residual borrow position after partial repay"

  -- ─── USER-INITIATED: Bob fully closes remaining debt ───
  (pool6, residualOpt2, _) <- submitMulti [bob] [operator] do
    exerciseCmd pool5 RepayBorrow with
      borrower = bob
      positionCid = residualBorrow
      repayAmount = 2000.0

  case residualOpt2 of
    Some _ -> abort "Expected no residual borrow position after full repay"
    None -> pure ()

  -- Old oracle contracts are now stale (next day with 1h max age), borrowing should fail.
  submitMustFail bob do
    exerciseCmd pool6 Borrow with
      borrower = bob
      borrowAmount = 100.0
      collateralAmount = 30.0
      oracleCid = usdcOracle
      collateralOracleCid = ccOracle

  -- Refresh oracle data.
  usdcOracleFresh <- submit oracle do
    exerciseCmd usdcOracle UpdatePrice with
      newPrice = 1.0
  ccOracleFresh <- submit oracle do
    exerciseCmd ccOracle UpdatePrice with
      newPrice = 10.0

  -- Borrow cap enforcement.
  submitMustFail bob do
    exerciseCmd pool6 Borrow with
      borrower = bob
      borrowAmount = 1300.0
      collateralAmount = 300.0
      oracleCid = usdcOracleFresh
      collateralOracleCid = ccOracleFresh

  -- ─── Open a new borrow to test liquidation ───
  (pool7, riskyBorrow, _) <- submitMulti [bob] [operator] do
    exerciseCmd pool6 Borrow with
      borrower = bob
      borrowAmount = 500.0
      collateralAmount = 120.0
      oracleCid = usdcOracleFresh
      collateralOracleCid = ccOracleFresh

  -- Drop collateral price so the position becomes liquidatable.
  ccOracleDown <- submit oracle do
    exerciseCmd ccOracleFresh UpdatePrice with
      newPrice = 5.0

  -- ─── OPERATOR-CONTROLLED: Liquidation ───
  (_pool8, _liquidationResidualOpt, _) <- submit operator do
    exerciseCmd pool7 LiquidateBorrow with
      liquidator = operator
      positionCid = riskyBorrow
      borrowOracleCid = usdcOracleFresh
      collateralOracleCid = ccOracleDown

  pure ()

  -- ─── USER-INITIATED: Alice withdraws her supply ───
  (_pool9, _, _) <- submitMulti [alice] [operator] do
    exerciseCmd _pool8 WithdrawSupply with
      supplier = alice
      positionCid = supplyPos

  return ()

-- | Test oracle price updates
testOracle : Script ()
testOracle = script do
  oracle <- allocateParty "Oracle"

  let startTime = time (date 2026 Jan 15) 12 0 0
  setTime startTime

  priceCid <- submit oracle do
    createCmd OraclePrice with
      oracle
      observers = []
      asset = "BTC"
      price = 50000.0
      lastUpdated = startTime
      minPrice = 10000.0
      maxPrice = 100000.0
      maxChangePercent = 0.5

  let nextTime = time (date 2026 Jan 15) 13 0 0
  setTime nextTime

  _newPriceCid <- submit oracle do
    exerciseCmd priceCid UpdatePrice with
      newPrice = 51000.0

  return ()
